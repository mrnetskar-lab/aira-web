const { queryRelevantMemories } = require('./memory-query');

/**

Bygg en kort system-prompt injection fra relevante minner.
@param {Object} opts
storyId: (string) filter memories
topK: (number) hvor mange minner å bruke (default 5)
maxChars: (number) maks lengde på injeksjon (default 800)
@returns {string} promptInjection */ function buildPromptInjection(opts = {}) { const { storyId, topK = 5, maxChars = 800 } = opts; const memories = queryRelevantMemories({ storyId, topK, lastN: 200 });
  if (!memories || memories.length === 0) {
    return '';
  }

  // Format hver memory kort: [beatId|timestamp] salientUtterances... (otherPerson summary)
  const parts = memories.map(m => {
    const tm = m.beatCompletedAt ? new Date(m.beatCompletedAt).toISOString().split('T')[0] : 'unknown-date';
    const beat = m.beatId || 'unknown-beat';
    const lines = (m.salientUtterances || []).slice(0,2).map(s => s.replace(/\s+/g, ' ').trim());
    const person = m.otherPerson && m.otherPerson.name ? ${m.otherPerson.name} (${m.otherPerson.appearance || 'appearance'}) : '';
    const imp = typeof m.importanceScore === 'number' ? imp=${m.importanceScore.toFixed(2)} : '';
    const snippet = lines.length ? lines.join(' | ') : '';
    return [${beat}|${tm}] ${snippet} ${person} ${imp}.trim();
  });

  let injection = Relevant memories:\n + parts.join('\n');

  // Trim to maxChars without breaking lines if possible
  if (injection.length > maxChars) {
    injection = injection.slice(0, maxChars - 3) + '...';
    // ensure doesn't end mid-utf8 sequence is fine in JS strings
  }

  return injection;
}

module.exports = { buildPromptInjection };

