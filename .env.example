# ── AI Provider (set ONE key — priority: OPENROUTER → GROQ → TOGETHER → OPENAI) ──
# OpenRouter: 100+ models via one key — anbefalt
OPENROUTER_API_KEY=

# Groq: gratis tier, rask, Llama 3.3-70b
GROQ_API_KEY=

# Together AI: åpne modeller inkl. uncensored varianter
TOGETHER_API_KEY=

# OpenAI: GPT-4.1-mini (fallback)
OPENAI_API_KEY=

# ── Bildegenerering ───────────────────────────────────────────────────────────
# FAL.ai: brukes til avatar/kamera-bilder
FAL_API_KEY=

# ── Per-karakter modeller (kun aktive når OpenRouter er i bruk) ───────────────
# Standard: nousresearch/hermes-3-llama-3.1-70b (anbefalt for alle)
# Eksempler:
#   LUCY_MODEL=nousresearch/hermes-3-llama-3.1-70b
#   SAM_MODEL=mistralai/mistral-medium
#   ANGIE_MODEL=meta-llama/llama-3.1-70b-instruct
#   HAZEL_MODEL=nousresearch/hermes-3-llama-3.1-70b
#   NINA_MODEL=nousresearch/hermes-3-llama-3.1-70b
LUCY_MODEL=
SAM_MODEL=
ANGIE_MODEL=
HAZEL_MODEL=
NINA_MODEL=

# ── Annet ─────────────────────────────────────────────────────────────────────
# Optional: overstyr modell globalt uavhengig av provider
# AI_MODEL=

PORT=3000
